# Git LFS tracking for large CAD and heavy media artifacts.
# Text/code files should remain normal Git objects.
# Keep common PDFs/PNGs out of global LFS to avoid retroactive pointer warnings
# for schematic PDFs and existing ROS/debug images that were already committed normally.

# Fusion 360 / CAD packages
*.f3z filter=lfs diff=lfs merge=lfs -text
*.f3d filter=lfs diff=lfs merge=lfs -text
*.step filter=lfs diff=lfs merge=lfs -text
*.stp filter=lfs diff=lfs merge=lfs -text
*.iges filter=lfs diff=lfs merge=lfs -text
*.igs filter=lfs diff=lfs merge=lfs -text
*.stl filter=lfs diff=lfs merge=lfs -text
*.dxf filter=lfs diff=lfs merge=lfs -text
*.dwg filter=lfs diff=lfs merge=lfs -text

# Office/binary source workbooks and presentations when intentionally committed
*.pptx filter=lfs diff=lfs merge=lfs -text
*.docx filter=lfs diff=lfs merge=lfs -text
*.xlsx filter=lfs diff=lfs merge=lfs -text

# Heavy validation media
*.mp4 filter=lfs diff=lfs merge=lfs -text
*.webm filter=lfs diff=lfs merge=lfs -text
*.mov filter=lfs diff=lfs merge=lfs -text
*.avi filter=lfs diff=lfs merge=lfs -text
*.trk filter=lfs diff=lfs merge=lfs -text

# Project photo and curated validation media folders.
# Existing scattered PNG/PDF files stay as normal Git files.
hardware/photos/** filter=lfs diff=lfs merge=lfs -text
electronics/images/** filter=lfs diff=lfs merge=lfs -text
validation/media/** filter=lfs diff=lfs merge=lfs -text
validation/tracker_files/** filter=lfs diff=lfs merge=lfs -text
